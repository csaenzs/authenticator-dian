# ===== DIAN =====
DIAN_ENV=hab
DIAN_CERT_PATH=/opt/tokendian/secrets/cert-modern.p12
DIAN_CERT_PASSWORD=cambiar
DIAN_USER_CODE=1117488256
DIAN_COMPANY_CODE=9015591465
DIAN_ID_TYPE=10910094

# ===== CapSolver =====
CAPSOLVER_API_KEY=CSAPI-...

# ===== Servicio =====
SERVICE_API_KEY=cambiar-por-token-largo-y-aleatorio
HEADLESS=true
LOG_LEVEL=INFO

# Segundos sin re-validar la sesión. Si llegan peticiones cercanas en el tiempo,
# solo la primera valida; las siguientes reusan la cache hasta que expire este TTL.
# 300 = 5 min. Subirlo (ej: 900 = 15 min) reduce más las llamadas a DIAN, pero
# aumenta la chance de devolver cookies expiradas (raro: DIAN suele dar 30+ min).
VALIDATION_TTL_SECONDS=300

# Rutas (opcionales, defaults sirven para una instalación estándar en /opt/tokendian)
COOKIES_PATH=/opt/tokendian/secrets/cookies.json
BROWSER_PROFILE_DIR=/opt/tokendian/.browser-profile
