# ===== Autenticación del servicio =====
# Token que el cliente debe enviar como header X-API-Key.
# Genera uno largo y aleatorio: openssl rand -hex 32
SERVICE_API_KEY=cambiar-por-token-largo-y-aleatorio

# ===== Comportamiento =====
HEADLESS=true
LOG_LEVEL=INFO

# Segundos sin re-validar la sesión. Mientras la última validación exitosa esté
# dentro de este TTL, las peticiones de cookies usan cache sin tocar DIAN.
# 300 (5 min) = balance razonable. Subir a 900 (15 min) reduce más la red, pero
# arriesga devolver cookies vencidas (DIAN suele dar 30+ min de sesión).
VALIDATION_TTL_SECONDS=300

# ===== Rutas (opcionales — defaults sirven en /opt/tokendian) =====
SESSIONS_DIR=/opt/tokendian/sessions
BROWSER_PROFILES_ROOT=/opt/tokendian/.browser-profiles

# Las credenciales DIAN (cert .p12, password, NIT, cédula) y la API key de
# CapSolver NO se configuran aquí: cada cliente las envía en /auth/login.
